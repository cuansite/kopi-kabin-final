GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Your production frontend URL (e.g. https://kopikabinfinal.vercel.app)
# For unified Vercel deployment, FRONTEND_URL and BACKEND_URL are the same domain.
VITE_APP_URL="https://your-app.vercel.app"
FRONTEND_URL="https://your-app.vercel.app"

# For a unified Vercel deployment (frontend + API on same domain), set this to the same URL.
# If you split frontend/backend across services, set this to your backend service URL.
BACKEND_URL="https://your-app.vercel.app"

# better-auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-better-auth-secret"

# PostgreSQL connection string (used by better-auth for session storage)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Supabase — find these in your project: Settings > API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — server only (server.ts). No VITE_ prefix — must NOT enter the client bundle.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
